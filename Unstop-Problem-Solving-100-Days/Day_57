def optimal_fibonacci_count(s):
    # Function to be implemented by the user
    """
    # Extract number from string
    # Generate fibbonaci numbers upto largest number found in the string
    # Identify the fibbonacci numbers
    # Count total number of fibbonacci found
    # List Fibonacci numbers extracted from string
    # Generate and list the first k fibonnaci numbers 
    """

    def extract_numbers(s):
        numbers = []
        current_number = ""
        for char in s:
            if char.isdigit():
                current_number += char
            else:
                if current_number:
                    numbers.append(int(current_number))
                    current_number = ""
        if current_number:
            numbers.append(int(current_number))
        return numbers
    
    def generate_fibbonacci_upto(max_value):
        fib_numbers = [0,1]
        while fib_numbers[-1] + fib_numbers[-2] <= max_value:
            fib_numbers.append(fib_numbers[-1] + fib_numbers[-2])
        return set(fib_numbers)

    # Generate the first K Fibonacci numbers
    def generate_first_k_fibonacci(k):
        if k == 0:
            return []
        if k == 1:
            return [0]
        fib_numbers = [0, 1]

        for _ in range(k - 2):
            fib_numbers.append(fib_numbers[-1] + fib_numbers[-2])
        return fib_numbers

    # Extract numbers from the input string
    numbers = extract_numbers(s)

    if not numbers:
        return 0
    
    max_number = max(numbers)

    fib_set = generate_fibbonacci_upto(max_number)
    found_fib_numbers = [num for num in numbers if num in fib_set]
    count_fib_numbers = len(found_fib_numbers)

    if count_fib_numbers == 0:
        return "0"
    else:
        output = f"{count_fib_numbers}\n"
        output += " ".join(map(str, found_fib_numbers)) + "\n"
        output += " ".join(map(str, generate_first_k_fibonacci(count_fib_numbers)))
        return output

    # return count, numbers, fib_set

if __name__ == '__main__':
    s = input().strip()
    print(optimal_fibonacci_count(s))