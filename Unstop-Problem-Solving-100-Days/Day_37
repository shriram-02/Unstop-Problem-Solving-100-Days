#include <stdio.h>

void user_logic(int n, int nums[]);

int main() {
    int n;
    scanf("%d", &n);
    int nums[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &nums[i]);
    }
    
    user_logic(n, nums);
    
    return 0;
}
void user_logic(int n, int nums[]) {
    long long sum = 0;

    for (int i = 0; i < n; i++) {
        if (i == 0 || nums[i] != nums[i - 1]) {
            sum += (1LL << nums[i]);
        }
    }

    printf("%lld", sum);
}